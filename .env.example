# WEEX AI Wars II — Environment Variables
# Copy to .env and fill in your values.
# NEVER commit .env to git.

# WEEX API Credentials (required for live; optional for paper public data)
WEEX_API_KEY=
WEEX_API_SECRET=
# Either name works (both supported in code):
WEEX_API_PASSPHRASE=
# WEEX_PASSPHRASE=

# Trading Configuration (config.yaml is source of truth for mode/symbols)
TRADING_MODE=paper
DEFAULT_LEVERAGE=5
MAX_LEVERAGE=8

# Dashboard (docker-compose)
DASHBOARD_PORT=8787
